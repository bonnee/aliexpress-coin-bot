# AliExpress Login Credentials
# Replace with your actual login information
ALIEXPRESS_EMAIL=your_email@example.com
ALIEXPRESS_PASSWORD=your_password

# Docker & Headless Settings
HEADLESS=true
TZ=UTC
CRON_SCHEDULE=0 0 * * *
RUN_ON_STARTUP=true
RUN_ONCE=false

# Telegram Bot Settings (Optional - for 2FA handling in headless mode)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here